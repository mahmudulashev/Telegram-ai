# Telegram API Credentials (Get from https://my.telegram.org)
API_ID=1234567
API_HASH=your_telegram_api_hash_here

# OpenAI / Gemini API Configuration
OPENAI_API_KEY=your_openai_or_gemini_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Admin Notification Settings
# Use "me" for Saved Messages, or enter your Telegram User/Chat ID (e.g. 123456789)
ADMIN_CHAT_ID=me

# Pyrogram Session File Name
SESSION_NAME=userbot_session
